{% extends 'backend/session/profile.html.twig' %}

{% set page_title = 'Confirmar Cambios - Deshabilitación de Asientos' %}

{% block subcontent %}
    <div class="alert alert-warning alert-dismissible fade in">
        <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
        <h4><i class="icon fa fa-warning"></i> ¡Atención!</h4>
        <p>Se detectaron <strong>{{ affected|length }} reservaciones activas</strong> en los asientos que va a deshabilitar.</p>
        <p>Estas reservaciones serán <strong>canceladas automáticamente</strong> y se devolverá el crédito a los usuarios.</p>
    </div>

    <div class="box box-warning">
        <div class="box-header with-border">
            <h3 class="box-title">Usuarios Afectados</h3>
        </div>
        <div class="box-body">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Asiento</th>
                        <th style="text-align: center;">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reservation in affected %}
                        <tr>
                            <td>
                                <strong>{{ reservation.user.name }} {{ reservation.user.lastname }}</strong>
                            </td>
                            <td>
                                <a href="mailto:{{ reservation.user.email }}">{{ reservation.user.email }}</a>
                            </td>
                            <td>
                                <span class="badge bg-red">{{ reservation.placeNumber }}</span>
                            </td>
                            <td style="text-align: center;">
                                <span class="label label-danger">Será cancelada</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="box">
        <div class="box-header with-border">
            <h3 class="box-title">Asientos a Deshabilitar</h3>
        </div>
        <div class="box-body">
            <div class="form-group">
                <div class="col-sm-12">
                    <p>
                        {% for place in disabled_places %}
                            <span class="badge bg-red" style="font-size: 16px; padding: 8px 12px; margin-right: 5px;">
                                Asiento {{ place }}
                            </span>
                        {% endfor %}
                    </p>
                </div>
            </div>
        </div>
    </div>

    <form method="POST" action="{{ path('backend_session_edit_confirm', { 'id': session.id }) }}" class="form-horizontal">
        <input type="hidden" name="_token" value="{{ csrf_token('session_edit_confirm') }}">
        <input type="hidden" name="confirmed" value="1">

        <div class="box">
            <div class="box-header with-border">
                <h3 class="box-title">Motivo del Cambio</h3>
                <p class="text-muted" style="font-size: 12px; margin-top: 5px;">Este campo es obligatorio</p>
            </div>
            <div class="box-body">
                <div class="form-group">
                    <label class="col-sm-2 control-label">Motivo <span class="text-danger">*</span></label>
                    <div class="col-sm-10">
                        <textarea 
                            name="reason" 
                            class="form-control" 
                            rows="4" 
                            placeholder="Ej: Daño estructural, Obstrucción de vista, Mantenimiento programado..."
                            required
                            minlength="10"
                            maxlength="500"
                        ></textarea>
                        <small class="form-text text-muted">
                            Mínimo 10 caracteres, máximo 500. Este registro quedará en auditoría.
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="col-sm-12">
                <div class="pull-right">
                    <a href="{{ path('backend_session_edit', { 'id': session.id }) }}" class="btn btn-default">
                        <i class="fa fa-times"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-danger" onclick="return confirm('¿Confirma la cancelación de {{ affected|length }} reservación(es) y devolución de crédito?');">
                        <i class="fa fa-check"></i> Confirmar y Procesar
                    </button>
                </div>
                <div class="clearfix"></div>
            </div>
        </div>
    </form>

    <div class="alert alert-info">
        <h5><i class="fa fa-info-circle"></i> Resumen de lo que sucederá:</h5>
        <ul>
            <li><strong>Cancelaciones:</strong> {{ affected|length }} reservación(es) serán canceladas</li>
            <li><strong>Créditos:</strong> Se devolverá 1 cupón/clase a cada usuario afectado</li>
            <li><strong>Auditoría:</strong> Se registrará quién, cuándo, por qué y qué usuarios fueron afectados</li>
            <li><strong>Notificación:</strong> Los usuarios serán afectados inmediatamente (futuro: email de notificación)</li>
        </ul>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(function() {
            // Validar que el motivo tenga al menos 10 caracteres
            $('textarea[name="reason"]').on('change', function() {
                var value = $(this).val().trim();
                if (value.length < 10) {
                    $(this).closest('.form-group').addClass('has-error');
                } else {
                    $(this).closest('.form-group').removeClass('has-error');
                }
            });
        });
    </script>
{% endblock %}
