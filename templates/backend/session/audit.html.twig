{% extends 'backend/session/profile.html.twig' %}

{% set page_title = 'Auditoría de Deshabilitaciones/Cancelaciones' %}
{% set active_tab = 'tab_audit' %}

{% block subcontent %}
    {% if audits | length > 0 %}
        <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
            <table class="table table-striped table-hover">
                <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                    <tr>
                        <th class="text-center">ID</th>
                        <th>Tipo</th>
                        <th>Ejecutado por</th>
                        <th class="text-center">Fecha / Hora</th>
                        <th class="text-center">Afectados</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    {% for audit in audits %}
                        {% set isAdminAudit = audit.auditType == 'place_disabled' %}
                        {% set isUserChangeAudit = audit.auditType in ['user_changed', 'user_changed_from', 'user_changed_to'] %}

                        <tr id="audit-row-{{ audit.id }}">
                            <td class="text-center"><strong>{{ audit.id }}</strong></td>
                            <td>
                                {% if audit.auditType == 'place_disabled' %}
                                    <span style="font-size: 1.05em;">ADMIN - Deshabilitación</span>
                                {% elseif audit.auditType == 'user_cancelled' %}
                                    <span style="font-size: 1.05em;">USUARIO - Cancelación</span>
                                {% elseif audit.auditType == 'user_changed_from' %}
                                    <span style="font-size: 1.05em;">USUARIO - Cambio (Salida)</span>
                                {% elseif audit.auditType == 'user_changed_to' %}
                                    <span style="font-size: 1.05em;">USUARIO - Cambio (Entrada)</span>
                                {% elseif audit.auditType == 'user_changed' %}
                                    <span style="font-size: 1.05em;">USUARIO - Cambio (Histórico)</span>
                                {% else %}
                                    <span style="font-size: 1.05em;">{{ audit.auditType }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if isAdminAudit %}
                                    <span style="font-size: 1.05em;">{{ audit.adminUserIdentifier }}</span>
                                {% else %}
                                    <span style="font-size: 1.05em;">{{ audit.userIdentifier }}</span>
                                {% endif %}
                            </td>
                            <td class="text-center">{{ audit.createdAt|date('d/m/Y H:i:s') }}</td>
                            <td class="text-center">{{ audit.affectedReservationsCount }}</td>
                            <td class="text-center">
                                {% if isAdminAudit or isUserChangeAudit %}
                                    <button type="button"
                                            class="btn btn-default btn-xs btn-audit-toggle"
                                            data-target="audit-detail-{{ audit.id }}"
                                            title="Ver detalles">
                                        <i class="fa fa-eye" aria-hidden="true"></i>
                                        <span class="js-label">Ver</span>
                                    </button>
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                        </tr>

                        {% if isAdminAudit %}
                            <tr id="audit-detail-{{ audit.id }}" class="audit-detail-row" style="display: none;">
                                <td colspan="6">
                                    <div class="well well-sm" style="margin: 0;">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <h5><strong>Motivo de deshabilitación</strong></h5>
                                                <p>{{ audit.reason ?: 'Sin motivo registrado' }}</p>

                                                <h5><strong>Asientos deshabilitados</strong></h5>
                                                {% if audit.disabledPlaces|length > 0 %}
                                                    {% for seat in audit.disabledPlaces %}
                                                        <span style="font-size: 1.05em; margin-right: 8px;">Asiento {{ seat }}</span>
                                                    {% endfor %}
                                                {% else %}
                                                    <span class="text-muted">Sin registros</span>
                                                {% endif %}
                                            </div>

                                            <div class="col-md-6">
                                                <h5><strong>Usuarios afectados ({{ audit.affectedUsers|length }})</strong></h5>
                                                {% if audit.affectedUsers|length > 0 %}
                                                    <div class="table-responsive">
                                                        <table class="table table-condensed">
                                                            <thead>
                                                                <tr>
                                                                    <th>ID</th>
                                                                    <th>Nombre</th>
                                                                    <th class="text-center">Asiento</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                {% for user in audit.affectedUsers %}
                                                                    <tr>
                                                                        <td>
                                                                            {% if user.id is defined and user.id %}
                                                                                <a href="{{ path('backend_user_show', { 'id': user.id }) }}" class="link-edit" title="Ver perfil del usuario">
                                                                                    <u>{{ user.id }}</u>
                                                                                    <i class="fa fa-eye" aria-hidden="true"></i>
                                                                                </a>
                                                                            {% else %}
                                                                                <span class="text-muted">N/A</span>
                                                                            {% endif %}
                                                                        </td>
                                                                        <td>
                                                                            <strong>{{ user.name }}</strong><br />
                                                                            <small class="text-muted">{{ user.email }}</small>
                                                                        </td>
                                                                        <td class="text-center">{{ user.place }}</td>
                                                                    </tr>
                                                                {% endfor %}
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                {% else %}
                                                    <span class="text-muted">Sin usuarios registrados</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% elseif isUserChangeAudit %}
                            {% set firstAffected = audit.affectedUsers|length > 0 ? audit.affectedUsers|first : {} %}
                            {% set userId = firstAffected.id ?? null %}
                            {% set fromSessionId = audit.fromSessionId is not null ? audit.fromSessionId : (firstAffected.from_session_id ?? null) %}
                            {% set toSessionId = audit.toSessionId is not null ? audit.toSessionId : (firstAffected.to_session_id ?? firstAffected.new_session_id ?? null) %}
                            {% set fromPlace = audit.fromPlace is not null ? audit.fromPlace : (firstAffected.from_place ?? null) %}
                            {% set toPlace = audit.toPlace is not null ? audit.toPlace : (firstAffected.to_place ?? firstAffected.place ?? null) %}

                            <tr id="audit-detail-{{ audit.id }}" class="audit-detail-row" style="display: none;">
                                <td colspan="6">
                                    <div class="well well-sm" style="margin: 0;">
                                        <h5><strong>Flujo de cambio</strong></h5>
                                        <div class="row">
                                            <div class="col-md-4">
                                                <strong>Usuario ID:</strong>
                                                {% if userId %}
                                                    <a href="{{ path('backend_user_show', { 'id': userId }) }}" class="link-edit" title="Ver perfil del usuario">
                                                        <u>{{ userId }}</u>
                                                        <i class="fa fa-eye" aria-hidden="true"></i>
                                                    </a>
                                                {% else %}
                                                    <span class="text-muted">N/A</span>
                                                {% endif %}
                                            </div>
                                            <div class="col-md-4">
                                                <strong>Sesión origen:</strong>
                                                {% if fromSessionId %}
                                                    <a href="{{ path('backend_session_edit', { 'id': fromSessionId }) }}" class="link-edit" title="Ver detalle de la sesión origen">
                                                        <u>{{ fromSessionId }}</u>
                                                        <i class="fa fa-eye" aria-hidden="true"></i>
                                                    </a>
                                                {% else %}
                                                    <span class="text-muted">N/A</span>
                                                {% endif %}
                                            </div>
                                            <div class="col-md-4">
                                                <strong>Sesión destino:</strong>
                                                {% if toSessionId %}
                                                    <a href="{{ path('backend_session_edit', { 'id': toSessionId }) }}" class="link-edit" title="Ver detalle de la sesión destino">
                                                        <u>{{ toSessionId }}</u>
                                                        <i class="fa fa-eye" aria-hidden="true"></i>
                                                    </a>
                                                {% else %}
                                                    <span class="text-muted">N/A</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <div class="row" style="margin-top: 10px;">
                                            <div class="col-md-4"><strong>Reserva:</strong> {{ audit.reservationId ?? 'N/A' }}</div>
                                            <div class="col-md-4"><strong>Asiento origen:</strong> {{ fromPlace ?? 'N/A' }}</div>
                                            <div class="col-md-4"><strong>Asiento destino:</strong> {{ toPlace ?? 'N/A' }}</div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        {{ include('backend/default/partials/not_records.html.twig') }}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(function () {
            $('.btn-audit-toggle').on('click', function () {
                var targetId = $(this).data('target');
                var $detailRow = $('#' + targetId);
                var $icon = $(this).find('i');
                var $label = $(this).find('.js-label');

                $detailRow.toggle();

                if ($detailRow.is(':visible')) {
                    $icon.removeClass('fa-eye').addClass('fa-eye-slash');
                    $label.text('Ocultar');
                } else {
                    $icon.removeClass('fa-eye-slash').addClass('fa-eye');
                    $label.text('Ver');
                }
            });
        });
    </script>
{% endblock %}
